# NexoCLI_BaseGemini Configuration
# Criado por Claude-Code, 2025
# Parte do NexoCLI_BaseGemini - Fork de gemini-cli (Google LLC, Apache 2.0)

# .env.example - Template para NexoCLI_BaseGemini
# (Usado apenas como template público, nunca inclui chaves reais)

# ===================================================================
# GEMINI - OAUTH GRATUITO (RECOMENDADO)
# ===================================================================
# Por defeito, NexoCLI_BaseGemini usa OAuth gratuito do Gemini
# 60 requests/minuto + 1000/dia SEM chave API necessária
# Descomente apenas se quiser quotas maiores:
# GEMINI_API_KEY=

# ===================================================================
# PROVIDERS EXTERNOS (OPCIONAIS)
# ===================================================================
# Descomente apenas os providers que pretende usar:

# OpenRouter - Gateway para 100+ modelos
# OPENROUTER_API_KEY=

# Anthropic - Claude (Sonnet, Opus, Haiku)
# ANTHROPIC_API_KEY=

# OpenAI - GPT-4, GPT-3.5-turbo
# OPENAI_API_KEY=

# Together AI - Modelos open-source
# TOGETHER_API_KEY=

# Fireworks AI - Modelos rápidos
# FIREWORKS_API_KEY=

# ===================================================================
# MODELOS LOCAIS (OLLAMA) - OPCIONAIS
# ===================================================================
# Configurações para modelos locais via Ollama
# Modelos binários ficam em ~/.ollama/ (instalação global)
# Projeto mantém apenas configurações

# Ollama service URL (local por defeito)
# OLLAMA_URL=http://localhost:11434

# Verificações de sistema (true/false)
# OLLAMA_CHECK_RESOURCES=true
# OLLAMA_MIN_RAM_MB=2048
# OLLAMA_TIMEOUT_MS=30000

# Modelo default para fallback local
# OLLAMA_DEFAULT_MODEL=phi3:mini

# ===================================================================
# CONFIGURAÇÕES DE SISTEMA (OPCIONAIS)
# ===================================================================
# LOG_LEVEL=info
# LOG_TO_DATABASE=true
# LOG_TO_FILE=true
# MAX_RETRIES=3
# REQUEST_TIMEOUT=30000
# FALLBACK_ENABLED=true

# ===================================================================
# CONFIGURAÇÕES AVANÇADAS (OPCIONAIS)
# ===================================================================
# Para utilizadores avançados
# CUSTOM_PROVIDER_URL=
# PROXY_URL=
# USER_AGENT_OVERRIDE=

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================
# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Log to database (recommended)
LOG_TO_DATABASE=true

# Log to files as well
LOG_TO_FILES=false

# Enable fallback between providers
FALLBACK_ENABLED=true

# Default provider priority
DEFAULT_PROVIDER=gemini

# Database configuration
DATABASE_PATH=./db/nexocli.db

# Backup configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# NODE_ENV=development
# DEBUG=nexocli:*